# ── Foodies Pakistan — FastAPI Microservice ──
# fastapi.foodiespakistan.pk
# General-purpose Python backend. Currently hosts: VR Tour module
# Copy this to .env and fill in real values.

# ── Service ──
PORT=8500
ENV=development

# ── Security (MUST match Node.js backend values) ──
VR_TOUR_SECRET=change_me_foodies_vr_tour_hmac_secret_2026
INTERNAL_SECRET=foodies_internal_bypass_secure_key_2024

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# ── CDN (same credentials as Node.js backend) ──
CDN_BASE_URL=http://localhost:3001
CDN_API_KEY=your_cdn_api_key_here

# ── Node.js API ──
API_BASE_URL=http://localhost:4000

# ── VR Tour Limits ──
MAX_SESSIONS_PER_HOUR=5
MAX_FRAMES_PER_SESSION=40
MAX_SCENES_PER_RESTAURANT=20
CAPTURE_TOKEN_EXPIRY_MINUTES=20
MAX_FRAME_SIZE_MB=8
PANORAMA_QUALITY=88
THUMBNAIL_WIDTH=640
